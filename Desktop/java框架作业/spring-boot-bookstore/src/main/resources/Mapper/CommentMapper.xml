<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.springbootbookstore.mapper.CommentMapper">
    <select id="selectCommentsById" parameterType="Integer" resultType="org.example.springbootbookstore.entity.Comment">
        select * from comment where book_id=#{id}
    </select>
</mapper>